{
  "name": "txdc-slack-assistant",
  "version": "1.0.0",
  "description": "Production-grade TXDC Slack Blockchain Assistant — human-readable blockchain payments via Slack",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,tests}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./jest-e2e.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create -d src/database/data-source.ts",
    "seed": "npx ts-node --project tsconfig.json scripts/seed.ts",
    "fund": "npx ts-node --project tsconfig.json scripts/fund-dev-accounts.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f",
    "docker:init-geth": "docker compose exec geth-node /scripts/geth-init.sh",
    "contract:compile": "node -e \"const fs=require('fs'),solc=require('solc');const o=JSON.parse(solc.compile(JSON.stringify({language:'Solidity',sources:{'IdentityRegistry.sol':{content:fs.readFileSync('contracts/IdentityRegistry.sol','utf8')}},settings:{optimizer:{enabled:true},outputSelection:{'*':{'*':['abi','evm.bytecode.object']}}}})));const c=o.contracts['IdentityRegistry.sol'].IdentityRegistry;fs.mkdirSync('contracts/build',{recursive:true});fs.writeFileSync('contracts/build/IdentityRegistry.abi',JSON.stringify(c.abi,null,2));fs.writeFileSync('contracts/build/IdentityRegistry.bin',c.evm.bytecode.object);console.log('Compiled: '+c.evm.bytecode.object.length+' hex chars');\"",
    "contract:deploy": "npm run contract:compile && npx ts-node --project tsconfig.json scripts/deploy-identity-registry.ts",
    "dev:up": "docker compose up -d postgres redis geth-node && echo 'Waiting for services...' && sleep 3 && npm run seed && echo 'Done. Run: npm run start:dev'",
    "dev:down": "docker compose down -v"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/typeorm": "^11.0.2",
    "@slack/web-api": "^6.10.0",
    "axios": "^1.6.0",
    "class-validator": "^0.14.0",
    "crypto-js": "^4.2.0",
    "ethers": "^6.9.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.19",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.6.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "solc": "^0.8.15",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
