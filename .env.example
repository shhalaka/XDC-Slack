# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=txdc
DB_PASSWORD=txdc_secret
DB_DATABASE=txdc_assistant

# ─── Slack ────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_OAUTH_REDIRECT_URI=https://yourdomain.com/api/slack/oauth/callback

# ─── Blockchain (Geth JSON-RPC) ──────────────────────────────
RPC_URL=http://localhost:8545
RPC_WS_URL=ws://localhost:8546
RPC_CHAIN_ID=8888
RPC_TIMEOUT_MS=30000
RPC_RETRY_COUNT=3
RPC_RETRY_DELAY_MS=1000

# Fallback RPC nodes (comma-separated)
RPC_FALLBACK_URLS=http://localhost:8546,http://localhost:8547

# ─── Wallet Security ─────────────────────────────────────────
# Do NOT store plaintext private keys.
# Use AWS KMS / HashiCorp Vault in production.
# For development, encrypted at rest using:
WALLET_ENCRYPTION_KEY=your-32-char-aes-key-here-change-in-prod

# ─── Token Configuration ─────────────────────────────────────
TOKEN_ADDRESS=0xYourTXDCContractAddress
TOKEN_DECIMALS=18
TOKEN_SYMBOL=TXDC
NATIVE_CURRENCY=TXDC

# ─── Identity Registry (ENS-style contract) ───────────────────
IDENTITY_REGISTRY_ADDRESS=0xYourRegistryContractAddress
IDENTITY_REGISTRY_DEPLOYED_BLOCK=0

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
DAILY_TRANSACTION_LIMIT=100
DAILY_VOLUME_LIMIT_ETH=1000

# ─── Observability ───────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=your_sentry_dsn

# ─── Redis (for queues and caching) ─────────────────────────
REDIS_URL=redis://localhost:6379
